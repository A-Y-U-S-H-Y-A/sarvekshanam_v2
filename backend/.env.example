# ─────────────────────────────────────────────
#  Sarvekshanam – Environment Configuration
#  Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# ── Database ──────────────────────────────────
# Use :memory: for ephemeral (tests), or an absolute path
DB_PATH=./sarvekshanam.db

# ── AI Providers ──────────────────────────────
# Replace with real keys – or leave as-is for mock/degraded mode
GROQ_API_KEY=gsk_mock_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-mock_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-mock_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Local AI (Ollama) ─────────────────────────
# Start Ollama: https://ollama.ai
OLLAMA_BASE_URL=http://localhost:11434

# ── Multi-System Proxy ────────────────────────
# PROXY_MODE: none | hop | direct
#   none   – all modules run locally
#   hop    – System B proxies module calls through System C before reaching Target
#   direct – modules route via System C directly to Target (A+B co-located)
PROXY_MODE=none
PROXY_TARGET=
# e.g. PROXY_TARGET=http://192.168.1.10:8080

# ── Command Execution ─────────────────────────
# ALLOWED_COMMANDS=* means ANY command is permitted (admin-approved)
# Otherwise, specify a comma-separated allowlist:
# ALLOWED_COMMANDS=nmap,ping,traceroute,dig,whois,curl
ALLOWED_COMMANDS=*

# ── CORS ──────────────────────────────────────
# Comma-separated origins, or * for all
CORS_ORIGINS=http://localhost:3000
